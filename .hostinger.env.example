# Copy these into Hostinger → Websites → your site → Environment variables.
# Generate APP_KEY locally: php artisan key:generate --show  (after composer install)
# Never commit real secrets or paste them in chat; rotate passwords if exposed.
# After deploy: php artisan migrate --force (SSH / Hostinger terminal).

APP_NAME="Eagle Academy"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://eagleacademy.site

LOG_CHANNEL=stack
LOG_LEVEL=error

# MySQL (hPanel → Websites → Databases). Names often look like: u123456789_yourdb / u123456789_youruser
DB_CONNECTION=mysql
# Use 127.0.0.1 or localhost — if connection fails, try the other (Hostinger varies).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u123456789_eagle
DB_USERNAME=u123456789_eagle
DB_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Requires migrated tables (sessions, cache, jobs, etc.)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
